{
  "version": 2,
  "builds": [
    {
      "src": "apps/api/main.js",
      "use": "@vercel/node",
      "config": { "maxLambdaSize": 50000000 }
    }
  ],
  "routes": [
    {
      "src": "/graphql",
      "dest": "apps/api/main.js"
    },
    {
      "src": "/(.*)",
      "dest": "apps/api/main.js"
    }
  ]
}